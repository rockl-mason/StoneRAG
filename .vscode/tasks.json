{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Spec Kit: Check Environment",
      "type": "shell",
      "command": "uvx",
      "args": ["--from", "specify-cli", "specify", "check"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "clear": true,
        "panel": "shared",
        "reveal": "always"
      }
    },
    {
      "label": "Spec Kit: Show Version",
      "type": "shell",
      "command": "uvx",
      "args": ["--from", "specify-cli", "specify", "version"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "shared",
        "reveal": "always"
      }
    }
  ]
}
